// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Cliente {
  id                String       @id @default(uuid())
  razonSocial       String       @map("razon_social")
  tipoDocumento     TipoDoc      @map("tipo_documento")
  numeroDocumento   String       @unique @map("numero_documento")
  tipoCliente       TipoCliente  @map("tipo_cliente")        
  numeroTelefono    String       @map("numero_telefono")
  correoElectronico String?      @unique @map("correo_electronico")
  
  activo            Boolean      @default(true)
  
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  @@map("clientes")
}

enum TipoDoc {
  DNI
  RUC
}

enum TipoCliente {
  MINORISTA
  MAYORISTA
}
