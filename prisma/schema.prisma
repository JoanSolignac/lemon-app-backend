// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Cliente {
  id                String       @id
  razonSocial       String       @map("razon_social")
  tipoDocumento     TipoDoc      @map("tipo_documento")
  numeroDocumento   String       @unique @map("numero_documento")
  tipoCliente       TipoCliente  @map("tipo_cliente")        
  numeroTelefono    String       @unique @map("numero_telefono")
  correoElectronico String?      @unique @map("correo_electronico")
  direccion         String      

  activo            Boolean      @default(true)
  version           Int          @default(1)
  
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")
  deletedAt         DateTime?    @map("deleted_at")

  @@map("clientes")
}

enum TipoDoc {
  DNI
  RUC
}

enum TipoCliente {
  MINORISTA
  MAYORISTA
}

model Usuario {
  id                String      @id
  rol               Rol      
  nombre            String      
  correoElectronico String      @unique
  contrasena        String

  activo            Boolean     @default(true)

  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt  @map("updated_at")
  deletedAt         DateTime?   @map("deleted_at")

  @@map("usuario")    
}

enum Rol {
  ADMINISTRADOR
  SUPERVISOR
}