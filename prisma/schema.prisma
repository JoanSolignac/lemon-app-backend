// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Usuario {
  id                String @id @default(uuid())
  rol               Rol
  nombre            String
  correoElectronico String @unique @map("correo_electronico")
  contrasena        String

  activo Boolean @default(true)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  dispositivos Dispositivo[]

  @@map("usuarios")
}

model Dispositivo {
  deviceId String @id @map("device_id")

  userId String @map("user_id")

  activo Boolean @default(true)

  lastSyncAt DateTime? @map("last_sync_at")

  metadata Json?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  usuario Usuario? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("dispositivos")
}

model Cliente {
  id String @id

  razonSocial String @map("razon_social")

  tipoDocumento TipoDoc @map("tipo_documento")

  numeroDocumento String @unique @map("numero_documento")

  tipoCliente TipoCliente @map("tipo_cliente")

  numeroTelefono String @unique @map("numero_telefono")

  correoElectronico String? @unique @map("correo_electronico")

  direccion String

  activo Boolean @default(true)

  version Int @default(1)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@map("clientes")
}

enum TipoDoc {
  DNI
  RUC
}

enum TipoCliente {
  MINORISTA
  MAYORISTA
}

enum Rol {
  ADMINISTRADOR
  SUPERVISOR
}
